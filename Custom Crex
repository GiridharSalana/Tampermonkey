    `;
    
    if (document.head) {
        document.head.appendChild(style);
        log('UI fixes injected');
    } else {
        document.addEventListener('DOMContentLoaded', () => {
            document.head.appendChild(style);
            log('UI fixes injected (delayed)');
        });
    }
}

function monitorUrlChanges() {
    if (urlObserver) {
        return;
    }
    urlObserver = new MutationObserver(() => {
        if (location.href !== lastUrl) {
            lastUrl = location.href;
            if (window.location.pathname.startsWith('/scoreboard/')) {
                log('Navigated to match page:', location.href);
                cleanup();
                setTimeout(initScript, STABILIZE_MS);
            }
        }
    });
    urlObserver.observe(document.body, { childList: true, subtree: true });
}

function cleanup() {
    if (scoreObserver) {
        scoreObserver.disconnect();
        scoreObserver = null;
    }
    const existing = document.getElementById('crex-tts-controls');
    if (existing) existing.remove();
    initialized = false;
}

function initScript() {
    if (initialized) return;
    initialized = true;
    log('Initializing on:', location.href);

    waitForElementToExist(SELECTORS.container_div).then(element => {
        log('Found container, injecting controls...');
        
        if (document.getElementById('crex-tts-controls')) {
            log('Controls already exist, skipping injection...');
            return;
        }
        
        var myDiv = element;
        myDiv.style.display = "flex";
        myDiv.style.flexDirection = "column";

        const controlsContainer = document.createElement("div");
        controlsContainer.id = 'crex-tts-controls';
        controlsContainer.style.cssText = `
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 18px;
            gap: 15px;
        `;

        // Mute button
        const muteButton = document.createElement("div");
        muteButton.textContent = "🔇";
        muteButton.id = "mute-btn";
        muteButton.style.cssText = `
            cursor: pointer;
            padding: 6px 10px;
            font-size: 20px;
            transition: transform 0.2s;
            opacity: 1;
        `;
        muteButton.onmouseover = () => { muteButton.style.transform = 'scale(1.15)'; };
        muteButton.onmouseout = () => { muteButton.style.transform = 'scale(1)'; };

        // Voice selector with better visibility
        const voiceSelector = document.createElement('select');
        voiceSelector.id = 'voiceSelect';
        voiceSelector.style.cssText = `
            padding: 6px 8px;
            border-radius: 4px;
            border: 1px solid rgba(255, 255, 255, 0.3);
            background-color: rgba(255, 255, 255, 0.15);
            color: #ffffff;
            font-size: 13px;
            font-weight: 500;
            cursor: pointer;
            outline: none;
            width: 180px;
            box-sizing: border-box;
            text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
        `;

        // Volume slider container - same total width as voice selector
        const volumeContainer = document.createElement('div');
        volumeContainer.style.cssText = `
            display: flex;
            align-items: center;
            gap: 6px;
            width: 180px;
            box-sizing: border-box;
        `;

        const lowVolumeIcon = document.createElement('span');
        lowVolumeIcon.textContent = '🔉';
        lowVolumeIcon.style.cssText = 'font-size: 16px; opacity: 0.9; flex-shrink: 0;';

        const volumeSlider = document.createElement('input');
        volumeSlider.type = 'range';
        volumeSlider.id = 'volume-slider';
        volumeSlider.min = '0';
        volumeSlider.max = '100';
        volumeSlider.value = volume;
        volumeSlider.style.cssText = `
            flex: 1;
            min-width: 0;
            cursor: pointer;
            accent-color: #4a9eff;
        `;

        const highVolumeIcon = document.createElement('span');
        highVolumeIcon.textContent = '🔊';
        highVolumeIcon.style.cssText = 'font-size: 16px; opacity: 0.9; flex-shrink: 0;';

        volumeContainer.appendChild(lowVolumeIcon);
        volumeContainer.appendChild(volumeSlider);
        volumeContainer.appendChild(highVolumeIcon);

        controlsContainer.appendChild(voiceSelector);
        controlsContainer.appendChild(muteButton);
        controlsContainer.appendChild(volumeContainer);

        myDiv.insertBefore(controlsContainer, myDiv.firstChild);

        function updateMuteUI() {
            if (isMute) {
                muteButton.textContent = "🔇";
                muteButton.setAttribute("title", "Unmute (Press M)");
            } else {
                muteButton.textContent = "🔊";
                muteButton.setAttribute("title", "Mute (Press M)");
            }
        }

        updateMuteUI();

        muteButton.addEventListener("click", function() {
            isMute = !isMute;
            localStorage.setItem('isMute', isMute);
            updateMuteUI();
            if (isMute) {
                window.speechSynthesis.cancel();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'm' || event.key === 'M') {
                muteButton.click();
            }
        });

        populateVoiceList();

        volumeSlider.addEventListener('input', function () {
            volume = volumeSlider.value;
            localStorage.setItem('volume', volume);
        });

        setupScoreMonitor();
    }).catch(err => log('Container not found:', err.message));
}

function updateMuteUI(btn1, btn2) {
    // Legacy function kept for compatibility
    if (btn1) {
        if (isMute) {
            btn1.textContent = "🔇";
            btn1.setAttribute("title", "Muted");
        } else {
            btn1.textContent = "🔊";
            btn1.setAttribute("title", "UnMuted");
        }
    }
    if (btn2) {
        if (isMute) {
            btn2.textContent = "🔇";
            btn2.setAttribute("title", "Muted");
        } else {
            btn2.textContent = "🔊";
            btn2.setAttribute("title", "UnMuted");
        }
    }
}

function setupScoreMonitor() {
    waitForElementToExist(SELECTORS.score_element).then(scoreEl => {
        log('Score element found, starting monitor...');
        scoreObserver = new MutationObserver(() => {
            changeCallback();
        });
        scoreObserver.observe(scoreEl, {
            childList: true,
            characterData: true,
            subtree: true,
            attributes: false,
        });
    }).catch(err => log('Score element not found:', err.message));
}

function changeCallback() {
    let el = document.querySelector(SELECTORS.score_element);
    if (!el) return;
    el.style.cursor = "pointer";
    let text = el.innerText.trim();
    if (!text) return;
    audioAnnouncer(text);
    scoreAnnouncer(text);
}

function audioAnnouncer(text) {
    if (!('speechSynthesis' in window)) {
        log('Text-to-speech is not supported in this browser.');
        return;
    }
    if (isMute) return;

    const synth = window.speechSynthesis;
    const utterance = new SpeechSynthesisUtterance(text);
    let voiceSelect = document.getElementById('voiceSelect');
    if (voiceSelect) {
        let voices = synth.getVoices();
        let selectedVoice = voices.find(v => v.name === voiceSelect.value);
        if (selectedVoice) utterance.voice = selectedVoice;
    }
    utterance.volume = convertVolume(volume);
    synth.speak(utterance);
}

function scoreAnnouncer(text) {
    if (text.toLowerCase().trim() !== 'over') return;

    const runsEl = document.querySelector(SELECTORS.score_runs);
    const oversEl = document.querySelector(SELECTORS.score_overs);

    if (runsEl && oversEl) {
        let runs_wkt = runsEl.innerText.trim();
        let overs = oversEl.innerText.trim();
        let scoreScript = runs_wkt.replace('-', ' Runs For ') + ' Wickets and ' + parseInt(overs) + ' Overs.';
        log('Over summary:', scoreScript);
        audioAnnouncer(scoreScript);
    }
}

function convertVolume(volumeString) {
    let volumeInt = parseInt(volumeString, 10);
    if (isNaN(volumeInt) || volumeInt < 0 || volumeInt > 100) {
        return 0.5;
    }
    return volumeInt / 100;
}


function waitForElementToExist(selector, timeout = 30000) {
    return new Promise((resolve, reject) => {
        const startTime = Date.now();

        const tryResolve = () => {
            setTimeout(() => {
                const el = document.querySelector(selector);
                if (el) {
                    resolve(el);
                } else {
                    startObserving();
                }
            }, STABILIZE_MS);
        };

        const startObserving = () => {
            const el = document.querySelector(selector);
            if (el) {
                tryResolve();
                return;
            }

            if (Date.now() - startTime > timeout) {
                reject(new Error('Timeout: ' + selector));
                return;
            }

            const observer = new MutationObserver(() => {
                if (document.querySelector(selector)) {
                    observer.disconnect();
                    tryResolve();
                }
            });

            observer.observe(document.body, {
                subtree: true,
                childList: true,
            });

            setTimeout(() => {
                observer.disconnect();
                if (!document.querySelector(selector)) {
                    reject(new Error('Timeout: ' + selector));
                }
            }, timeout - (Date.now() - startTime));
        };

        startObserving();
    });
}

function getVoices() {
    return new Promise((resolve, reject) => {
        if (!('speechSynthesis' in window)) {
            reject(new Error('Speech synthesis not supported'));
            return;
        }
        let synth = window.speechSynthesis;
        let voices = synth.getVoices();
        if (voices.length > 0) {
            resolve(voices);
            return;
        }
        synth.onvoiceschanged = () => {
            resolve(synth.getVoices());
        };
    });
}

function populateVoiceList() {
    let voiceSelect = document.getElementById('voiceSelect');
    if (!voiceSelect) return;

    getVoices()
        .then(voices => {
            voices.forEach(voice => {
                let option = document.createElement('option');
                option.textContent = voice.name;
                option.setAttribute('data-lang', voice.lang);
                option.setAttribute('data-name', voice.name);
                voiceSelect.appendChild(option);
            });
            let selectedVoice = localStorage.getItem('selectedVoice');
            if (selectedVoice) {
                voiceSelect.value = selectedVoice;
            }
        })
        .catch(error => {
            log('Error retrieving voices:', error);
        });

    voiceSelect.addEventListener('change', function () {
        localStorage.setItem('selectedVoice', voiceSelect.value);
    });
}

function getThemeFromCookie() {
    const cookie = document.cookie.split('; ').find(row => row.startsWith('system-theme='));
    return cookie ? cookie.split('=')[1] : null;
}

function setThemeCookie(theme) {
    const expires = new Date();
    expires.setFullYear(expires.getFullYear() + 1);
    document.cookie = `system-theme=${theme}; expires=${expires.toUTCString()}; path=/`;
    log('Theme cookie set:', theme);
}

function fixThemePersistence() {
    log('Setting up theme monitoring...');
    
    const cookieTheme = getThemeFromCookie();
    const htmlTheme = document.documentElement.getAttribute('data-theme');
    
    // Save cookie if we have a theme but no cookie
    if (htmlTheme && !cookieTheme) {
        log('Saving current theme to cookie:', htmlTheme);
        setThemeCookie(htmlTheme);
    } else if (!htmlTheme && !cookieTheme) {
        log('No theme found, setting default: light');
        setThemeCookie('light');
        document.documentElement.setAttribute('data-theme', 'light');
    }
    
    // Monitor for theme changes
    const observer = new MutationObserver((mutations) => {
        for (let mutation of mutations) {
            if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                const newTheme = document.documentElement.getAttribute('data-theme');
                if (newTheme) {
                    const currentCookie = getThemeFromCookie();
                    if (currentCookie !== newTheme) {
                        log('Theme changed to:', newTheme, '- Updating cookie...');
                        setThemeCookie(newTheme);
                    }
                }
            }
        }
    });
    
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme']
    });
    
    log('Theme monitoring active - watching data-theme attribute on <html>');
}
