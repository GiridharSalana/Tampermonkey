// ==UserScript==
// @name         Custom Crex
// @namespace    http://tampermonkey.net/
// @version      4.5
// @description  TTS score announcer with modern glassmorphism UI and modal voice selector for crex.com
// @author       You
// @match        https://crex.com/*
// @icon         https://crex.com/assets/icon/favicon.ico
// @grant        none
// @run-at       document-start
// ==/UserScript==

// IMMEDIATE THEME FIX - Runs before page renders to prevent flicker
(function() {
    'use strict';
    
    function getThemeFromCookie() {
        const cookie = document.cookie.split('; ').find(row => row.startsWith('system-theme='));
        return cookie ? cookie.split('=')[1] : null;
    }
    
    function setThemeCookie(theme) {
        const expires = new Date();
        expires.setFullYear(expires.getFullYear() + 1);
        document.cookie = `system-theme=${theme}; expires=${expires.toUTCString()}; path=/`;
    }
    
    const savedTheme = getThemeFromCookie();
    if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
    }
})();

var isMute = localStorage.getItem('isMute');
var volume = localStorage.getItem('volume');

isMute = isMute !== null ? isMute : true;
volume = volume !== null ? volume : '50';

isMute = isMute === 'true';

const SELECTORS = {
    container_div: '.live-score-header.mob-none app-match-details-wrapper .team-result > div',
    score_element: '.live-score-header.mob-none app-match-details-wrapper .team-result > div > span',
    score_runs: '.live-score-header.mob-none app-match-details-wrapper .team-score > div > span:first-child',
    score_overs: '.live-score-header.mob-none app-match-details-wrapper .team-score > div > span:nth-child(2)',
    theme_toggle: 'header .head-right-ui .nav-items .theme-toggle',
};
const LOG_PREFIX = '[CustomCrex]';
const STABILIZE_MS = 2500;

let scoreObserver = null;
let urlObserver = null;
let lastUrl = location.href;
let initialized = false;

function log(...args) {
    console.log(LOG_PREFIX, ...args);
}

(function () {
    'use strict';

    // Wait for DOM to be ready since we're running at document-start
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeScript);
    } else {
        initializeScript();
    }
})();

function initializeScript() {
    injectUIFixes();
    fixThemePersistence();

    if (!window.location.pathname.startsWith('/scoreboard/')) {
        log('Not a match page, waiting for SPA navigation...');
        monitorUrlChanges();
        return;
    }

    initScript();
}

function injectUIFixes() {
    const style = document.createElement('style');
    style.id = 'crex-ui-fixes';
    style.textContent = `
        /* Center and balance the main content area */
        .match-detail-container,
        .match-info-container,
        .scorecard-container {
            max-width: 1200px;
            margin: 0 auto !important;
            padding: 0 20px;
        }
        
        /* Center the commentary section */
        .commentary-section,
        app-commentary {
            max-width: 1200px;
            margin: 0 auto !important;
            padding: 0 20px;
        }
        
        /* Balance the player cards section */
        .player-cards-wrapper,
        .player-of-match {
            display: flex;
            justify-content: center !important;
            align-items: center;
            margin: 0 auto;
        }
        
        /* Center the probability section */
        .probability-container {
            max-width: 1200px;
            margin: 0 auto !important;
            display: flex;
            justify-content: center;
            padding: 20px;
        }
        
        /* Fix tab content centering */
        .tab-content,
        .match-detail-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }
        
        /* Center scorecard tables */
        .scorecard-table,
        table.scorecard {
            margin: 0 auto !important;
        }
        
        /* Balance team stats */
        .team-stats-wrapper {
            max-width: 1200px;
            margin: 0 auto !important;
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        
        /* Center match info sections */
        .match-info-section {
            max-width: 1200px;
            margin: 0 auto !important;
            text-align: center;
        }
        
        /* Fix angular component centering */
        app-match-info,
        app-scorecard,
        app-live-score {
            display: block;
            max-width: 1200px;
            margin: 0 auto !important;
        }
        
        /* Center the main content wrapper */
        .main-content,
        .content-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        /* Improve voice selector dropdown visibility */
        #voiceSelect option {
            background-color: #1a1a2e !important;
            color: #ffffff !important;
            padding: 8px !important;
            font-size: 13px !important;
        }
        
        #voiceSelect option:checked,
        #voiceSelect option:hover {
            background-color: #4a9eff !important;
            color: #ffffff !important;
        }
    `;
    
    if (document.head) {
        document.head.appendChild(style);
        log('UI fixes injected');
    } else {
        document.addEventListener('DOMContentLoaded', () => {
            document.head.appendChild(style);
            log('UI fixes injected (delayed)');
        });
    }
}

function monitorUrlChanges() {
    if (urlObserver) {
        return;
    }
    urlObserver = new MutationObserver(() => {
        if (location.href !== lastUrl) {
            lastUrl = location.href;
            if (window.location.pathname.startsWith('/scoreboard/')) {
                log('Navigated to match page:', location.href);
                cleanup();
                setTimeout(initScript, STABILIZE_MS);
            }
        }
    });
    urlObserver.observe(document.body, { childList: true, subtree: true });
}

function cleanup() {
    if (scoreObserver) {
        scoreObserver.disconnect();
        scoreObserver = null;
    }
    const existing = document.getElementById('crex-tts-controls');
    if (existing) existing.remove();
    initialized = false;
}

function initScript() {
    if (initialized) return;
    initialized = true;
    log('Initializing on:', location.href);

    log('About to call waitForElementToExist...');
    
    waitForElementToExist(SELECTORS.container_div).then(element => {
        log('Found container, injecting controls...');
        
        if (document.getElementById('crex-tts-controls')) {
            log('Controls already exist, skipping injection...');
            return;
        }
        
        log('Creating controls...');
        var myDiv = element;
        myDiv.style.display = "flex";
        myDiv.style.flexDirection = "column";

        const controlsContainer = document.createElement("div");
        controlsContainer.id = 'crex-tts-controls';
        controlsContainer.style.cssText = `
            display: flex;
            align-items: center;
            justify-content: center;
            margin-top: 18px;
            gap: 20px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.15);
            border-radius: 30px;
            padding: 8px 20px;
            box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
            width: fit-content;
            margin-left: auto;
            margin-right: auto;
        `;

        // Voice icon button
        const voiceIconBtn = document.createElement("div");
        voiceIconBtn.id = "voice-icon-btn";
        voiceIconBtn.textContent = "🎤";
        voiceIconBtn.title = "Select Voice";
        voiceIconBtn.style.cssText = `
            cursor: pointer;
            font-size: 22px;
            padding: 6px;
            border-radius: 50%;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        `;
        voiceIconBtn.onmouseover = () => {
            voiceIconBtn.style.background = 'rgba(255, 255, 255, 0.15)';
            voiceIconBtn.style.transform = 'scale(1.1)';
        };
        voiceIconBtn.onmouseout = () => {
            voiceIconBtn.style.background = 'transparent';
            voiceIconBtn.style.transform = 'scale(1)';
        };

        // Modal overlay
        const modalOverlay = document.createElement("div");
        modalOverlay.id = 'voice-modal-overlay';
        modalOverlay.style.cssText = `
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0, 0, 0, 0.7);
            backdrop-filter: blur(5px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100000;
            animation: fadeIn 0.2s ease;
        `;

        // Modal content
        const modalContent = document.createElement("div");
        modalContent.id = 'voice-modal-content';
        modalContent.style.cssText = `
            background: rgba(30, 30, 45, 0.98);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 16px;
            padding: 24px;
            max-width: 400px;
            width: 90%;
            max-height: 500px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.8);
            animation: slideIn 0.3s ease;
        `;

        // Modal header
        const modalHeader = document.createElement("div");
        modalHeader.style.cssText = `
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        `;

        const modalTitle = document.createElement("h3");
        modalTitle.textContent = "Select Voice";
        modalTitle.style.cssText = `
            color: #ffffff;
            font-size: 20px;
            font-weight: 600;
            margin: 0;
        `;

        const closeBtn = document.createElement("div");
        closeBtn.textContent = "✕";
        closeBtn.style.cssText = `
            cursor: pointer;
            font-size: 24px;
            color: rgba(255, 255, 255, 0.6);
            transition: all 0.2s ease;
            padding: 4px 8px;
            border-radius: 4px;
        `;
        closeBtn.onmouseover = () => {
            closeBtn.style.color = '#ffffff';
            closeBtn.style.background = 'rgba(255, 255, 255, 0.1)';
        };
        closeBtn.onmouseout = () => {
            closeBtn.style.color = 'rgba(255, 255, 255, 0.6)';
            closeBtn.style.background = 'transparent';
        };

        modalHeader.appendChild(modalTitle);
        modalHeader.appendChild(closeBtn);

        // Voice list container
        const voiceList = document.createElement("div");
        voiceList.id = 'voice-list';
        voiceList.style.cssText = `
            max-height: 400px;
            overflow-y: auto;
            margin-top: 16px;
            padding-right: 8px;
        `;
        
        // Custom scrollbar styling
        const scrollbarStyle = document.createElement('style');
        scrollbarStyle.textContent = `
            #voice-list::-webkit-scrollbar {
                width: 8px;
            }
            #voice-list::-webkit-scrollbar-track {
                background: rgba(255, 255, 255, 0.05);
                border-radius: 4px;
            }
            #voice-list::-webkit-scrollbar-thumb {
                background: rgba(255, 255, 255, 0.3);
                border-radius: 4px;
                transition: background 0.3s ease;
            }
            #voice-list::-webkit-scrollbar-thumb:hover {
                background: rgba(255, 255, 255, 0.5);
            }
        `;
        document.head.appendChild(scrollbarStyle);

        modalContent.appendChild(modalHeader);
        modalContent.appendChild(voiceList);
        modalOverlay.appendChild(modalContent);
        document.body.appendChild(modalOverlay);

        // Voice icon wrapper
        const voiceIconWrapper = document.createElement('div');
        voiceIconWrapper.style.cssText = `
            display: flex;
            align-items: center;
        `;

        // Hidden select for voice data
        const voiceSelector = document.createElement('select');
        voiceSelector.id = 'voiceSelect';
        voiceSelector.style.display = 'none';

        // Toggle modal
        let isModalOpen = false;
        let voicesPopulated = false;
        
        voiceIconBtn.onclick = (e) => {
            e.stopPropagation();
            isModalOpen = true;
            modalOverlay.style.display = 'flex';
            document.body.style.overflow = 'hidden'; // Prevent background scroll
            
            // Populate voices when opening modal if not already done
            if (!voicesPopulated) {
                voiceList.innerHTML = '<div style="padding: 20px; color: #fff; text-align: center;">Loading voices...</div>';
                populateVoiceListNow();
            }
        };

        // Close modal
        closeBtn.onclick = () => {
            modalOverlay.style.display = 'none';
            isModalOpen = false;
            document.body.style.overflow = ''; // Re-enable background scroll
        };

        modalOverlay.onclick = (e) => {
            if (e.target === modalOverlay) {
                modalOverlay.style.display = 'none';
                isModalOpen = false;
                document.body.style.overflow = ''; // Re-enable background scroll
            }
        };

        function populateVoiceListNow() {
            getVoices().then(voices => {
                voiceList.innerHTML = ''; // Clear loading message
                let selectedVoice = localStorage.getItem('selectedVoice');
                
                if (voices.length === 0) {
                    voiceList.innerHTML = '<div style="padding: 20px; color: #fff; text-align: center;">No voices available</div>';
                    return;
                }
                
                voices.forEach(voice => {
                    // Add to hidden select
                    let option = document.createElement('option');
                    option.textContent = voice.name;
                    option.setAttribute('data-lang', voice.lang);
                    option.setAttribute('data-name', voice.name);
                    voiceSelector.appendChild(option);
                    
                    // Add to modal list
                    let voiceItem = document.createElement('div');
                    voiceItem.textContent = voice.name;
                    voiceItem.style.cssText = `
                        padding: 12px 16px;
                        cursor: pointer;
                        border-radius: 10px;
                        font-size: 14px;
                        color: #ffffff;
                        transition: all 0.2s ease;
                        margin-bottom: 8px;
                        ${selectedVoice === voice.name ? 'background: rgba(74, 158, 255, 0.4); font-weight: 600; border: 1px solid rgba(74, 158, 255, 0.6);' : 'border: 1px solid transparent;'}
                    `;
                    voiceItem.onmouseover = () => {
                        if (selectedVoice !== voice.name) {
                            voiceItem.style.background = 'rgba(255, 255, 255, 0.1)';
                        }
                    };
                    voiceItem.onmouseout = () => {
                        if (selectedVoice !== voice.name) {
                            voiceItem.style.background = 'transparent';
                        }
                    };
                    voiceItem.onclick = () => {
                        voiceSelector.value = voice.name;
                        localStorage.setItem('selectedVoice', voice.name);
                        modalOverlay.style.display = 'none';
                        isModalOpen = false;
                        document.body.style.overflow = ''; // Re-enable background scroll
                        
                        // Update all voice items
                        Array.from(voiceList.children).forEach(item => {
                            if (item.textContent === voice.name) {
                                item.style.background = 'rgba(74, 158, 255, 0.4)';
                                item.style.fontWeight = '600';
                                item.style.border = '1px solid rgba(74, 158, 255, 0.6)';
                            } else {
                                item.style.background = 'transparent';
                                item.style.fontWeight = 'normal';
                                item.style.border = '1px solid transparent';
                            }
                        });
                    };
                    voiceList.appendChild(voiceItem);
                });
                
                if (selectedVoice) {
                    voiceSelector.value = selectedVoice;
                }
                
                voicesPopulated = true;
            }).catch(error => {
                voiceList.innerHTML = '<div style="padding: 20px; color: #ff8888; text-align: center;">Error loading voices</div>';
                log('Error retrieving voices:', error);
            });
        }

        voiceIconWrapper.appendChild(voiceIconBtn);

        // Volume slider container with modern styling
        const volumeContainer = document.createElement('div');
        volumeContainer.style.cssText = `
            display: flex;
            align-items: center;
            gap: 12px;
        `;

        const lowVolumeIcon = document.createElement('span');
        lowVolumeIcon.textContent = '🔉';
        lowVolumeIcon.style.cssText = `
            font-size: 18px;
            opacity: 0.9;
            flex-shrink: 0;
            transition: all 0.3s ease;
            cursor: pointer;
        `;
        lowVolumeIcon.onmouseover = () => { lowVolumeIcon.style.opacity = '1'; lowVolumeIcon.style.transform = 'scale(1.1)'; };
        lowVolumeIcon.onmouseout = () => { lowVolumeIcon.style.opacity = '0.9'; lowVolumeIcon.style.transform = 'scale(1)'; };

        const volumeSlider = document.createElement('input');
        volumeSlider.type = 'range';
        volumeSlider.id = 'volume-slider';
        volumeSlider.min = '0';
        volumeSlider.max = '100';
        volumeSlider.value = volume;
        volumeSlider.style.cssText = `
            width: 120px;
            cursor: pointer;
            accent-color: #4a9eff;
            transition: all 0.3s ease;
        `;
        volumeSlider.onmouseover = () => { volumeSlider.style.transform = 'scaleY(1.2)'; };
        volumeSlider.onmouseout = () => { volumeSlider.style.transform = 'scaleY(1)'; };

        const highVolumeIcon = document.createElement('span');
        highVolumeIcon.textContent = '🔊';
        highVolumeIcon.style.cssText = `
            font-size: 18px;
            opacity: 0.9;
            flex-shrink: 0;
            transition: all 0.3s ease;
            cursor: pointer;
        `;
        highVolumeIcon.onmouseover = () => { highVolumeIcon.style.opacity = '1'; highVolumeIcon.style.transform = 'scale(1.1)'; };
        highVolumeIcon.onmouseout = () => { highVolumeIcon.style.opacity = '0.9'; highVolumeIcon.style.transform = 'scale(1)'; };

        volumeContainer.appendChild(lowVolumeIcon);
        volumeContainer.appendChild(volumeSlider);
        volumeContainer.appendChild(highVolumeIcon);

        // Mute button with circular background
        const muteButton = document.createElement("div");
        muteButton.textContent = "🔇";
        muteButton.id = "mute-btn";
        muteButton.title = "Mute/Unmute (M)";
        muteButton.style.cssText = `
            cursor: pointer;
            padding: 8px;
            font-size: 20px;
            border-radius: 50%;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        `;
        muteButton.onmouseover = () => { 
            muteButton.style.background = 'rgba(255, 255, 255, 0.15)';
            muteButton.style.transform = 'scale(1.1)';
        };
        muteButton.onmouseout = () => { 
            muteButton.style.background = 'transparent';
            muteButton.style.transform = 'scale(1)';
        };

        controlsContainer.appendChild(voiceIconWrapper);
        controlsContainer.appendChild(volumeContainer);
        controlsContainer.appendChild(muteButton);

        myDiv.insertBefore(controlsContainer, myDiv.firstChild);

        function updateMuteUI() {
            if (isMute) {
                muteButton.textContent = "🔇";
                muteButton.setAttribute("title", "Unmute (Press M)");
            } else {
                muteButton.textContent = "🔊";
                muteButton.setAttribute("title", "Mute (Press M)");
            }
        }

        updateMuteUI();

        muteButton.addEventListener("click", function() {
            isMute = !isMute;
            localStorage.setItem('isMute', isMute);
            updateMuteUI();
            if (isMute) {
                window.speechSynthesis.cancel();
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'm' || event.key === 'M') {
                muteButton.click();
            }
        });

        populateVoiceList();

        volumeSlider.addEventListener('input', function () {
            volume = volumeSlider.value;
            localStorage.setItem('volume', volume);
        });

        setupScoreMonitor();
    }).catch(err => log('Container not found:', err.message));
}

function updateMuteUI(btn1, btn2) {
    // Legacy function kept for compatibility
    if (btn1) {
        if (isMute) {
            btn1.textContent = "🔇";
            btn1.setAttribute("title", "Muted");
        } else {
            btn1.textContent = "🔊";
            btn1.setAttribute("title", "UnMuted");
        }
    }
    if (btn2) {
        if (isMute) {
            btn2.textContent = "🔇";
            btn2.setAttribute("title", "Muted");
        } else {
            btn2.textContent = "🔊";
            btn2.setAttribute("title", "UnMuted");
        }
    }
}

function setupScoreMonitor() {
    waitForElementToExist(SELECTORS.score_element).then(scoreEl => {
        log('Score element found, starting monitor...');
        scoreObserver = new MutationObserver(() => {
            changeCallback();
        });
        scoreObserver.observe(scoreEl, {
            childList: true,
            characterData: true,
            subtree: true,
            attributes: false,
        });
    }).catch(err => log('Score element not found:', err.message));
}

function changeCallback() {
    let el = document.querySelector(SELECTORS.score_element);
    if (!el) return;
    el.style.cursor = "pointer";
    let text = el.innerText.trim();
    if (!text) return;
    audioAnnouncer(text);
    scoreAnnouncer(text);
}

function audioAnnouncer(text) {
    if (!('speechSynthesis' in window)) {
        log('Text-to-speech is not supported in this browser.');
        return;
    }
    if (isMute) return;

    const synth = window.speechSynthesis;
    const utterance = new SpeechSynthesisUtterance(text);
    let voiceSelect = document.getElementById('voiceSelect');
    if (voiceSelect) {
        let voices = synth.getVoices();
        let selectedVoice = voices.find(v => v.name === voiceSelect.value);
        if (selectedVoice) utterance.voice = selectedVoice;
    }
    utterance.volume = convertVolume(volume);
    synth.speak(utterance);
}

function scoreAnnouncer(text) {
    if (text.toLowerCase().trim() !== 'over') return;

    const runsEl = document.querySelector(SELECTORS.score_runs);
    const oversEl = document.querySelector(SELECTORS.score_overs);

    if (runsEl && oversEl) {
        let runs_wkt = runsEl.innerText.trim();
        let overs = oversEl.innerText.trim();
        let scoreScript = runs_wkt.replace('-', ' Runs For ') + ' Wickets and ' + parseInt(overs) + ' Overs.';
        log('Over summary:', scoreScript);
        audioAnnouncer(scoreScript);
    }
}

function convertVolume(volumeString) {
    let volumeInt = parseInt(volumeString, 10);
    if (isNaN(volumeInt) || volumeInt < 0 || volumeInt > 100) {
        return 0.5;
    }
    return volumeInt / 100;
}


function waitForElementToExist(selector, timeout = 30000) {
    return new Promise((resolve, reject) => {
        const startTime = Date.now();
        
        log('Waiting for element:', selector);

        const tryResolve = () => {
            setTimeout(() => {
                const el = document.querySelector(selector);
                if (el) {
                    log('Element found after wait:', selector);
                    resolve(el);
                } else {
                    log('Element not found after stabilize delay, starting observer...');
                    startObserving();
                }
            }, STABILIZE_MS);
        };

        const startObserving = () => {
            const el = document.querySelector(selector);
            if (el) {
                log('Element found immediately:', selector);
                tryResolve();
                return;
            }

            if (Date.now() - startTime > timeout) {
                log('TIMEOUT: Element not found:', selector);
                reject(new Error('Timeout: ' + selector));
                return;
            }

            const observer = new MutationObserver(() => {
                if (document.querySelector(selector)) {
                    log('Element found by observer:', selector);
                    observer.disconnect();
                    tryResolve();
                }
            });

            observer.observe(document.body, {
                subtree: true,
                childList: true,
            });

            setTimeout(() => {
                observer.disconnect();
                if (!document.querySelector(selector)) {
                    log('TIMEOUT: Element never appeared:', selector);
                    reject(new Error('Timeout: ' + selector));
                }
            }, timeout - (Date.now() - startTime));
        };

        startObserving();
    });
}

function getVoices() {
    return new Promise((resolve, reject) => {
        if (!('speechSynthesis' in window)) {
            reject(new Error('Speech synthesis not supported'));
            return;
        }
        let synth = window.speechSynthesis;
        let voices = synth.getVoices();
        if (voices.length > 0) {
            resolve(voices);
            return;
        }
        synth.onvoiceschanged = () => {
            resolve(synth.getVoices());
        };
    });
}

function populateVoiceList() {
    let voiceSelect = document.getElementById('voiceSelect');
    let voicePopup = document.getElementById('voice-popup');
    if (!voiceSelect || !voicePopup) return;

    getVoices()
        .then(voices => {
            let selectedVoice = localStorage.getItem('selectedVoice');
            
            voices.forEach(voice => {
                // Add to hidden select
                let option = document.createElement('option');
                option.textContent = voice.name;
                option.setAttribute('data-lang', voice.lang);
                option.setAttribute('data-name', voice.name);
                voiceSelect.appendChild(option);
                
                // Add to popup menu
                let voiceItem = document.createElement('div');
                voiceItem.textContent = voice.name;
                voiceItem.style.cssText = `
                    padding: 10px 12px;
                    cursor: pointer;
                    border-radius: 8px;
                    font-size: 13px;
                    color: #ffffff;
                    transition: all 0.2s ease;
                    ${selectedVoice === voice.name ? 'background: rgba(74, 158, 255, 0.3); font-weight: 600;' : ''}
                `;
                voiceItem.onmouseover = () => {
                    if (selectedVoice !== voice.name) {
                        voiceItem.style.background = 'rgba(255, 255, 255, 0.1)';
                    }
                };
                voiceItem.onmouseout = () => {
                    if (selectedVoice !== voice.name) {
                        voiceItem.style.background = 'transparent';
                    }
                };
                voiceItem.onclick = () => {
                    voiceSelect.value = voice.name;
                    localStorage.setItem('selectedVoice', voice.name);
                    voicePopup.style.display = 'none';
                    
                    // Update all voice items
                    Array.from(voicePopup.children).forEach(item => {
                        if (item.textContent === voice.name) {
                            item.style.background = 'rgba(74, 158, 255, 0.3)';
                            item.style.fontWeight = '600';
                        } else {
                            item.style.background = 'transparent';
                            item.style.fontWeight = 'normal';
                        }
                    });
                };
                voicePopup.appendChild(voiceItem);
            });
            
            if (selectedVoice) {
                voiceSelect.value = selectedVoice;
            }
        })
        .catch(error => {
            log('Error retrieving voices:', error);
        });
}

function getThemeFromCookie() {
    const cookie = document.cookie.split('; ').find(row => row.startsWith('system-theme='));
    return cookie ? cookie.split('=')[1] : null;
}

function setThemeCookie(theme) {
    const expires = new Date();
    expires.setFullYear(expires.getFullYear() + 1);
    document.cookie = `system-theme=${theme}; expires=${expires.toUTCString()}; path=/`;
    log('Theme cookie set:', theme);
}

function fixThemePersistence() {
    log('Setting up theme monitoring...');
    
    const cookieTheme = getThemeFromCookie();
    const htmlTheme = document.documentElement.getAttribute('data-theme');
    
    // Save cookie if we have a theme but no cookie
    if (htmlTheme && !cookieTheme) {
        log('Saving current theme to cookie:', htmlTheme);
        setThemeCookie(htmlTheme);
    } else if (!htmlTheme && !cookieTheme) {
        log('No theme found, setting default: light');
        setThemeCookie('light');
        document.documentElement.setAttribute('data-theme', 'light');
    }
    
    // Monitor for theme changes
    const observer = new MutationObserver((mutations) => {
        for (let mutation of mutations) {
            if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
                const newTheme = document.documentElement.getAttribute('data-theme');
                if (newTheme) {
                    const currentCookie = getThemeFromCookie();
                    if (currentCookie !== newTheme) {
                        log('Theme changed to:', newTheme, '- Updating cookie...');
                        setThemeCookie(newTheme);
                    }
                }
            }
        }
    });
    
    observer.observe(document.documentElement, {
        attributes: true,
        attributeFilter: ['data-theme']
    });
    
    log('Theme monitoring active - watching data-theme attribute on <html>');
}
