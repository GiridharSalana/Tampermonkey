// ==UserScript==
// @name         Custom Crex
// @namespace    http://tampermonkey.net/
// @version      3.4
// @description  TTS score announcer with wider controls and proper margin for crex.com
// @author       You
// @match        https://crex.com/*
// @icon         https://crex.com/assets/icon/favicon.ico
// @grant        none
// @run-at       document-start
// ==/UserScript==

// IMMEDIATE THEME FIX - Runs before page renders to prevent flicker
(function() {
    'use strict';
    
    function getThemeFromCookie() {
        const cookie = document.cookie.split('; ').find(row => row.startsWith('system-theme='));
        return cookie ? cookie.split('=')[1] : null;
    }
    
    function setThemeCookie(theme) {
        const expires = new Date();
        expires.setFullYear(expires.getFullYear() + 1);
        document.cookie = `system-theme=${theme}; expires=${expires.toUTCString()}; path=/`;
    }
    
    const savedTheme = getThemeFromCookie();
    if (savedTheme) {
        document.documentElement.setAttribute('data-theme', savedTheme);
    }
})();

var isMute = localStorage.getItem('isMute');
var volume = localStorage.getItem('volume');

isMute = isMute !== null ? isMute : true;
volume = volume !== null ? volume : '50';

isMute = isMute === 'true';

const SELECTORS = {
    container_div: '.live-score-header.mob-none app-match-details-wrapper .team-result > div',
    score_element: '.live-score-header.mob-none app-match-details-wrapper .team-result > div > span',
    score_runs: '.live-score-header.mob-none app-match-details-wrapper .team-score > div > span:first-child',
    score_overs: '.live-score-header.mob-none app-match-details-wrapper .team-score > div > span:nth-child(2)',
    theme_toggle: 'header .head-right-ui .nav-items .theme-toggle',
};
const LOG_PREFIX = '[CustomCrex]';
const STABILIZE_MS = 2500;

let scoreObserver = null;
let urlObserver = null;
let lastUrl = location.href;
let initialized = false;

function log(...args) {
    console.log(LOG_PREFIX, ...args);
}

(function () {
    'use strict';

    // Wait for DOM to be ready since we're running at document-start
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initializeScript);
    } else {
        initializeScript();
    }
})();

function initializeScript() {
    injectUIFixes();
    fixThemePersistence();

    if (!window.location.pathname.startsWith('/scoreboard/')) {
        log('Not a match page, waiting for SPA navigation...');
        monitorUrlChanges();
        return;
    }

    initScript();
}

function injectUIFixes() {
    const style = document.createElement('style');
    style.id = 'crex-ui-fixes';
    style.textContent = `
        /* Center and balance the main content area */
        .match-detail-container,
        .match-info-container,
        .scorecard-container {
            max-width: 1200px;
            margin: 0 auto !important;
            padding: 0 20px;
        }
        
        /* Center the commentary section */
        .commentary-section,
        app-commentary {
            max-width: 1200px;
            margin: 0 auto !important;
            padding: 0 20px;
        }
        
        /* Balance the player cards section */
        .player-cards-wrapper,
        .player-of-match {
            display: flex;
            justify-content: center !important;
            align-items: center;
            margin: 0 auto;
        }
        
        /* Center the probability section */
        .probability-container {
            max-width: 1200px;
            margin: 0 auto !important;
            display: flex;
            justify-content: center;
            padding: 20px;
        }
        
        /* Fix tab content centering */
        .tab-content,
        .match-detail-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
            width: 100%;
        }
        
        /* Center scorecard tables */
        .scorecard-table,
        table.scorecard {
            margin: 0 auto !important;
        }
        
        /* Balance team stats */
        .team-stats-wrapper {
            max-width: 1200px;
            margin: 0 auto !important;
            display: flex;
            justify-content: center;
            gap: 20px;
        }
        
        /* Center match info sections */
        .match-info-section {
            max-width: 1200px;
            margin: 0 auto !important;
            text-align: center;
        }
        
        /* Fix angular component centering */
        app-match-info,
        app-scorecard,
        app-live-score {
            display: block;
            max-width: 1200px;
            margin: 0 auto !important;
        }
        
        /* Center the main content wrapper */
        .main-content,
        .content-wrapper {
            display: flex;
            flex-direction: column;
            align-items: center;
        }
        
        /* Improve voice selector dropdown visibility */
        #voiceSelect option {
            background-color: #1a1a2e !important;
            color: #ffffff !important;
            padding: 8px !important;
            font-size: 13px !important;
        }
        
        #voiceSelect option:checked,
        #voiceSelect option:hover {
